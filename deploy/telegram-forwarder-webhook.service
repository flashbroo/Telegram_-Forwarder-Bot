[Unit]
Description=Telegram Forwarder Razorpay Webhook
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=telegrambot
Group=telegrambot
WorkingDirectory=/opt/telegram-forwarder-bot
EnvironmentFile=/opt/telegram-forwarder-bot/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/telegram-forwarder-bot/.venv/bin/uvicorn razorpay_webhook:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5
TimeoutStopSec=20
KillSignal=SIGINT
NoNewPrivileges=true
PrivateTmp=true
UMask=0077
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
